# =============================================================================
# stake-move-automation — configuration template
# Copy this to .env and fill in your values.
#   cp env.example .env
# =============================================================================


# =============================================================================
# SECTION 1 — Wallet & Network  (REQUIRED by daily_stake_move.py)
# =============================================================================

# Name of the Bittensor cold-key wallet (must exist on the host running the service)
WALLET_NAME=your_wallet_name

# Cold-key password for the wallet above
WALLET_PASSWORD=your_wallet_password

# Subnet UID that contains the origin hotkey
ORIGIN_NETUID=35

# Subnet UID that contains the destination hotkey (can be the same as ORIGIN_NETUID)
DEST_NETUID=35

# SS58 address of the hotkey to sweep FROM
ORIGIN_HOTKEY=your_origin_hotkey_ss58

# SS58 address of the hotkey to sweep INTO
DEST_HOTKEY=your_destination_hotkey_ss58

# Minimum stake (in α) below which the sweep is skipped  [default: 0.001]
# MINIMUM_STAKE_THRESHOLD=0.001


# =============================================================================
# SECTION 2 — Telegram Notifications  (optional)
# =============================================================================

# Create a bot via @BotFather → copy the token it gives you
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Chat ID where notifications are sent (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_telegram_chat_id


# =============================================================================
# SECTION 3 — Google Sheets Logging  (optional)
# =============================================================================

# Absolute path to the service-account JSON file on the host
# The file must have "Editor" access to the sheet below
GOOGLE_SERVICE_ACCOUNT_JSON=/opt/stake-move-automation/google-sheets-sa.json

# The part of the sheet URL after /d/  e.g. https://docs.google.com/spreadsheets/d/<ID>/
GOOGLE_SHEET_ID=your_google_sheet_id


# =============================================================================
# SECTION 4 — Sheet Setup  (only needed when running setup_sheets.py)
# These values are written into the sheet once and not read again at runtime.
# =============================================================================

# Opening TAO balance when tracking started (numeric)
OPENING_BALANCE=0.0

# Date tracking started  (YYYY-MM-DD)
OPENING_DATE=2026-01-01

# --- Partners ---
# How many partners are sharing distributions (supports any number ≥ 1)
PARTNER_COUNT=2

# Partner 1
PARTNER_1_NAME=GTV
PARTNER_1_SHARE=0.5
PARTNER_1_WALLET=your_partner_1_wallet_ss58

# Partner 2
PARTNER_2_NAME=PTN
PARTNER_2_SHARE=0.5
PARTNER_2_WALLET=your_partner_2_wallet_ss58

# Add more partners by continuing the pattern:
# PARTNER_3_NAME=XYZ
# PARTNER_3_SHARE=0.333
# PARTNER_3_WALLET=your_partner_3_wallet_ss58
# (Shares should sum to 1.0 across all partners)

# First distribution date  (YYYY-MM-DD)
FIRST_DIST_DATE=2026-01-10

# Distribution cycle in days
CYCLE_DAYS=14

# Comma-separated tab names to rename as [Archive] before setup
# Leave empty (or omit) for a fresh sheet with no legacy tabs to archive
# ARCHIVE_TAB_NAMES=Distribution,Transactions,Shares & Configs
